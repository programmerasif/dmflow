generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String        @map("password_hash")
  emailVerified Boolean       @default(false) @map("email_verified")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  adminProfile  AdminProfile?

  @@map("admins")
}

model AdminProfile {
  id          String   @id @default(uuid())
  adminId     String   @unique @map("admin_id")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  avatarUrl   String?  @map("avatar_url")
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model User {
  id                            String    @id @default(uuid())
  email                         String    @unique
  passwordHash                  String    @map("password_hash")
  emailVerified                 Boolean   @default(false) @map("email_verified")
  emailVerificationOtp          String?   @map("email_verification_otp")
  emailVerificationOtpExpiresAt DateTime? @map("email_verification_otp_expires_at")
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  profile           Profile?
  connectedAccounts ConnectedAccounts[]
  messages          Message[]
  categories        Category[]

  @@map("users")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  avatarUrl   String?  @map("avatar_url")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model ConnectedAccounts {
  id       String    @id @default(uuid())
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]
  messages Message[]
}

enum Platform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  GMAIL
}

model Account {
  id                   String             @id @default(uuid())
  name                 Platform
  username             String?
  expiresIn        Int?              @map("expires_in") 
  accessToken          String             @map("access_token")
  refreshToken         String?            @map("refresh_token")
  expiresAt            DateTime?          @map("expires_at")
  longLivedAccessToken String?            @map("long_lived_access_token")
  lastSyncAt           DateTime?          @map("last_sync_at")
  connectedAccountId   String?            @map("connected_account_id")
  connectedAccount     ConnectedAccounts? @relation(fields: [connectedAccountId], references: [id])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

enum MessageTag {
  SPONSOR
  COLLAB
  FAN
  SPAM
  OTHER
}

enum MessagePriority {
  URGENT
  IMPORTANT
  NORMAL
}

model Message {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  platform           Platform
  senderName         String            @map("sender_name")
  senderUserName     String?           @map("sender_username")
  senderAvatarUrl    String?           @map("sender_avatar_url")
  content            String            @db.Text
  subject            String?
  receivedAt         DateTime          @map("received_at")
  tag                MessageTag        @default(OTHER)
  priority           MessagePriority   @default(NORMAL)
  metadata           Json?             @db.Json
  priorityReason     String?           @map("priority_reason")
  isRead             Boolean           @default(false) @map("is_read")
  isArchived         Boolean           @default(false) @map("is_archived")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  categoryId         String?           @map("category_id")
  category           Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  connectedAccountId String            @map("connected_account_id")
  connectedAccount   ConnectedAccounts @relation(fields: [connectedAccountId], references: [id])

  @@map("messages")
}
