{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/src/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "prisma/schema.prisma",
          "generated/prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/src/app.js"
    }
  ]
}